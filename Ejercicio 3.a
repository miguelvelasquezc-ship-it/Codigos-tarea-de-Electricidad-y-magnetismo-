import numpy as np
import matplotlib.pyplot as plt

#Constantes
k = 1  #se pone 1 para simplificar
q = 1  #carga puntual

#creacion de malla de puntos
x = np.linspace(-5, 5, 40)  #valores del eje x desde -5 hasta 5 usando 40 puntos
y = np.linspace(-5, 5, 40)  #valores del eje y desde -5 hasta 5 usando 40 puntos
X, Y = np.meshgrid(x, y)   #malla bidimensional

#Distancia de cada punto respecto a la carga ubicada en el origen
R = np.sqrt(X**2 + Y**2)
R[R == 0] = 1e-9

Ex = k * q * X / R**3  #Campo electrico en x
Ey = k * q * Y / R**3  #Campo electrico en y
#magnitud del  campo electrico
E = np.sqrt(Ex**2 + Ey**2)
#normalizar vectores
Ex_n = Ex / E
Ey_n = Ey / E
#ventana para grafica
plt.figure(figsize=(6,6))
#dibujar lineas de flujo de campo
plt.streamplot(X, Y, Ex, Ey, color=E, cmap='plasma', density=1.2)
#dibujar las flechas del campo
plt.quiver(X[::3,::3], Y[::3,::3], Ex_n[::3,::3], Ey_n[::3,::3], scale=30)

plt.title("Campo eléctrico (1 carga)")
plt.xlabel("x")
plt.ylabel("y")
plt.grid()
plt.show()
