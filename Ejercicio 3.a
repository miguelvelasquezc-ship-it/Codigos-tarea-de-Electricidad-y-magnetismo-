import numpy as np
import matplotlib.pyplot as plt

k = 1
q = 1

x = np.linspace(-5, 5, 40)
y = np.linspace(-5, 5, 40)
X, Y = np.meshgrid(x, y)

R = np.sqrt(X**2 + Y**2)
R[R == 0] = 1e-9

Ex = k * q * X / R**3
Ey = k * q * Y / R**3

E = np.sqrt(Ex**2 + Ey**2)

Ex_n = Ex / E
Ey_n = Ey / E

plt.figure(figsize=(6,6))

plt.streamplot(X, Y, Ex, Ey, color=E, cmap='plasma', density=1.2)

plt.quiver(X[::3,::3], Y[::3,::3], Ex_n[::3,::3], Ey_n[::3,::3], scale=30)

plt.title("Campo eléctrico (1 carga)")
plt.xlabel("x")
plt.ylabel("y")
plt.grid()
plt.show()
