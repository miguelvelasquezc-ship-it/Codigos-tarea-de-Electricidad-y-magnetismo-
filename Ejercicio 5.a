import numpy as np
import matplotlib.pyplot as plt

#constante de coulomb
k = 8.99e9
#carga fija
Q = 100e-6
#carga oscilante
q = 1e-15
#masa de la particula
m = 1e-6
#distancia caracteristica del sistema
d = 1
#amplitud de oscilacion
A = 0.1

#calcular frecuencia angular del movimiento armonico simple
omega = np.sqrt((16 * k * Q * q) / (m * d**3))

#calcular periodo de oscilacion
T = 2 * np.pi / omega

#mostrar resultados principales
print("Frecuencia angular =", omega)
print("Periodo =", T)

#generar tiempos desde 0 hasta 2 periodos
#usando 30 puntos
t = np.linspace(0, 2*T, 30)

#ecuacion de posicion:
#x(t) = A cos(wt)
x = A * np.cos(omega * t)

#ecuacion de velocidad:
#v(t) = -Aw sen(wt)
v = -A * omega * np.sin(omega * t)


#imprimir encabezado de tabla
print("\n t\t\t x(t)\t\t v(t)")
print("-"*45)

#recorrer todos los valores calculados
for i in range(len(t)):

    #imprimir tiempo, posicion y velocidad
    print(f"{t[i]:.5f}\t {x[i]:.5f}\t {v[i]:.5f}")

#crear figura para la grafica
plt.figure(figsize=(10,5))

#graficar posicion en funcion del tiempo
plt.plot(
    t,
    x,
    'o-',
    label='Posición x(t)'
)

#graficar velocidad en funcion del tiempo
plt.plot(
    t,
    v,
    's-',
    label='Velocidad v(t)'
)

#etiqueta del eje x
plt.xlabel('Tiempo')
#etiqueta del eje y
plt.ylabel('Magnitud')
#titulo de la grafica
plt.title('Movimiento Armónico Simple de la carga q')

plt.grid(True)
plt.legend()
plt.show()
