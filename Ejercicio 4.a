import numpy as np
import matplotlib.pyplot as plt

#constantes
k = 8.99e9                  #Constante de Coulomb
e = 1.602e-19               #Carga del electrón/protón
mp = 1.67e-27               #Masa del protón
me = 9.11e-31               #Masa del electrón

#datos
q = 100 * e                 #Carga positiva (+q)
Q = e                       #Magnitud de la carga del electrón (-Q)
d = 1e-10                   #Distancia entre protones (1 Å)


x0 = 5e-11                  #Posición inicial del electrón
v0 = 0                      #Parte desde reposo


dt = 1e-18                  #Paso temporal
N = 30                      #Número de posiciones solicitadas


x = [x0]
v = [v0]
t = [0]


for i in range(N - 1):

    #Campo eléctrico total sobre el eje x
    #Distancia a cada carga positiva
    r = np.sqrt(x[i]**2 + (d/2)**2)

    #Fuerza eléctrica neta sobre el electrón
    #El signo negativo aparece porque el electrón es negativo
    Fx = -2 * k * q * Q * x[i] / (r**3)

    #Aceleración
    ax = Fx / me

    #Actualización
    vn = v[i] + ax * dt
    xn = x[i] + vn * dt

    #Guardar datos
    v.append(vn)
    x.append(xn)
    t.append(t[i] + dt)

#Conversion de unidades
x_angstrom = np.array(x) * 1e10   # m -> Å
v_km = np.array(v) / 1000         # m/s -> km/s

print(" n        x (Å)           v (km/s)")
print("-" * 40)

for i in range(N):
    print(f"{i:2d}   {x_angstrom[i]:12.6f}   {v_km[i]:12.6f}")

plt.figure(figsize=(12,5))

#Posicion
plt.subplot(1,2,1)
plt.plot(t, x_angstrom, 'bo-')
plt.xlabel("Tiempo (s)")
plt.ylabel("Posición x (Å)")
plt.title("Posición del electrón")
plt.grid(True)

#Velocidad
plt.subplot(1,2,2)
plt.plot(t, v_km, 'ro-')
plt.xlabel("Tiempo (s)")
plt.ylabel("Velocidad (km/s)")
plt.title("Velocidad del electrón")
plt.grid(True)

plt.tight_layout()
plt.show()
